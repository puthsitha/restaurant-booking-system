# Base URL of the TableSite backend API.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Google OAuth client ID (Web application), used for the diner "Continue with
# Google" button. Must be the same client ID as backend/.env's GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
