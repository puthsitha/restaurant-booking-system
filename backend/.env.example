# ─── Required ────────────────────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tablesite?schema=public"
# Secret used to sign/verify JWTs. Generate with: openssl rand -base64 48
JWT_SECRET="dev-only-change-me"
# Google OAuth client ID (Web application) used to verify Google ID tokens.
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# ─── Server ──────────────────────────────────────────────────────────────────
# Node environment: development | test | production
NODE_ENV=development
# API server port
PORT=4000

# ─── Security ────────────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins allowed to call the API (CORS).
CORS_ORIGIN="http://localhost:3000"
# Rate limit: max requests per IP per window, and the window length in ms.
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW_MS=900000
# Maximum accepted JSON request body size.
JSON_BODY_LIMIT=100kb
# How long an issued JWT stays valid (jsonwebtoken "zeit/ms" style string or seconds).
JWT_EXPIRES_IN=7d
